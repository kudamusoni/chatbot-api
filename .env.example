APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173
WIDGET_PUBLIC_BASE_URL=http://localhost:82
# Backward-compatible alias (prefer WIDGET_PUBLIC_BASE_URL)
WIDGET_BASE_URL=http://localhost:82
WIDGET_SCRIPT_PATH=embed.js
WIDGET_API_URL=http://localhost:5173
# Optional absolute override (wins over WIDGET_PUBLIC_BASE_URL/WIDGET_BASE_URL/WIDGET_SCRIPT_PATH)
# WIDGET_SCRIPT_URL=https://widget.example.com/embed.js
VERIFICATION_RESEND_COOLDOWN_SECONDS=60

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AI_ENABLED=false
AI_PROVIDER=openai
AI_OPENAI_API_KEY=
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL_CHAT=gpt-4o-mini
AI_MODEL_NORMALIZE=gpt-4o-mini
AI_TIMEOUT_SECONDS=12
AI_MAX_OUTPUT_TOKENS=300
AI_TEMPERATURE=0.2
AI_ASSISTANT_MAX_CHARS=1200
AI_FALLBACK_ASSISTANT_MESSAGE="I'm having trouble right now. Can you rephrase that?"
AI_MAX_REQUESTS_PER_MINUTE_PER_CLIENT=30
AI_DAILY_COST_CAP_MINOR_PER_CLIENT=5000
AI_DAILY_REQUEST_CAP_PER_CLIENT=2000
AI_POLICY_VERSION=
AI_CIRCUIT_ENABLED=true
AI_CIRCUIT_FAILURE_THRESHOLD=5
AI_CIRCUIT_COOLDOWN_SECONDS=120
AI_CIRCUIT_GLOBAL_FAILURE_THRESHOLD=30
AI_CIRCUIT_GLOBAL_COOLDOWN_SECONDS=120

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
